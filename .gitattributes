# Auto detect text files and normalize line endings to LF in the repository.
# Windows devs can keep CRLF locally; Git will convert on commit.
* text=auto eol=lf

# Explicit overrides for text files
*.ts          text eol=lf
*.js          text eol=lf
*.mjs         text eol=lf
*.cjs         text eol=lf
*.json        text eol=lf
*.md          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.prisma      text eol=lf
*.env         text eol=lf
*.env.example text eol=lf
Dockerfile    text eol=lf
.dockerignore text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf
.prettierrc   text eol=lf
.eslintrc*    text eol=lf

# Binary files - never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
